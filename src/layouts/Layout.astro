---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Jacob Simpson — Freelance Astro & WordPress Developer',
  description = "Jacob Simpson — freelance developer building fast, modern sites with Astro & WordPress. Clean code, great Core Web Vitals, shipped on time.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="ahrefs-site-verification"
      content="32d53a595ce533c7faa107060e66fdb2e03ab630b591f129785876929ae03dc6"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <!-- Ahrefs Web Analytics -->
    <script
      src="https://analytics.ahrefs.com/analytics.js"
      data-key="HM7YkNsnLmFiXYo0JTPLJQ"
      async></script>
  </head>
  <body>
    <slot />
  </body>
</html>
