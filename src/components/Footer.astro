---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner container mono">
    <span>© {year} Jacob Simpson</span>
    <span>built with Astro energy ⚡</span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border-band);
    padding: 30px 32px;
  }

  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 12px;
    font-size: 12.5px;
    color: var(--muted-dim);
  }
</style>
