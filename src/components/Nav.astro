---
const githubUrl = 'https://github.com/jacobsimpsondev';
---

<nav class="nav">
  <div class="nav__inner container">
    <a href="#top" class="nav__brand mono">
      <span class="nav__dot"></span>
      ~/jacobsimpsondev
    </a>
    <div class="nav__links mono">
      <a href="#skills" class="nav__link">skills</a>
      <a href="#services" class="nav__link">services</a>
      <a href="#contact" class="nav__link">contact</a>
      <a href={githubUrl} target="_blank" rel="noopener" class="nav__github">
        GitHub ↗
      </a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    background: rgba(8, 11, 17, 0.82);
    border-bottom: 1px solid var(--border-nav);
  }

  .nav__inner {
    padding: 0 32px;
    height: 66px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav__brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--nav-text);
  }

  .nav__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 10px rgba(63, 185, 80, 0.7);
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: 30px;
    font-size: 13.5px;
    color: var(--muted);
  }

  .nav__link {
    transition: color 0.15s;
  }

  .nav__link:hover {
    color: var(--green);
  }

  .nav__github {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    border: 1px solid var(--border-outline);
    border-radius: 7px;
    color: var(--nav-text);
    transition: border-color 0.15s;
  }

  .nav__github:hover {
    border-color: var(--green);
  }
</style>
